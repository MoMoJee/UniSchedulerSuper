{
    "_comment": "API 密钥配置文件，将后缀中的 .example 去除后使用",
    "_注意": "此文件包含敏感信息，请妥善保管。必须有此文件才能启动服务",

    "provider_styles": {
        "_description": "LLM Provider 兼容风格定义。system_models 通过 style 字段引用这里的配置。",
        "deepseek": {
            "label": "DeepSeek OpenAI-compatible",
            "request": {
                "chat_api": "openai-compatible",
                "message_format": "openai-chat",
                "image_block": "none",
                "tool_name": "openai-compatible"
            },
            "thinking": {
                "mode_param": "deepseek",
                "enabled_extra_body": {"thinking": {"type": "enabled"}},
                "disabled_extra_body": {"thinking": {"type": "disabled"}},
                "enabled_extra_kwargs": {"reasoning_effort": "high"}
            },
            "usage": {
                "input_tokens": ["usage.input_tokens", "usage.prompt_tokens"],
                "output_tokens": ["usage.output_tokens", "usage.completion_tokens"],
                "cache_hit_input_tokens": ["usage.prompt_cache_hit_tokens", "usage.prompt_tokens_details.cached_tokens"],
                "cache_miss_input_tokens": ["usage.prompt_cache_miss_tokens"],
                "reasoning_tokens": ["usage.completion_tokens_details.reasoning_tokens"]
            },
            "billing": {
                "input_cache_miss_price_key": "cost_per_1k_input_cache_miss",
                "input_cache_hit_price_key": "cost_per_1k_input_cache_hit",
                "output_price_key": "cost_per_1k_output"
            }
        },
        "kimi": {
            "label": "Moonshot/Kimi OpenAI-compatible",
            "request": {
                "chat_api": "openai-compatible",
                "message_format": "openai-chat",
                "image_block": "openai-image-url",
                "tool_name": "openai-compatible"
            },
            "thinking": {
                "mode_param": "kimi-k2",
                "enabled_extra_body": {"thinking": {"type": "enabled", "keep": "all"}},
                "disabled_extra_body": {"thinking": {"type": "disabled", "keep": "all"}},
                "enabled_defaults": {"temperature": 1.0, "min_max_tokens": 16000}
            },
            "usage": {
                "input_tokens": ["usage.input_tokens", "usage.prompt_tokens"],
                "output_tokens": ["usage.output_tokens", "usage.completion_tokens"],
                "cache_hit_input_tokens": ["usage.cached_tokens"],
                "cache_miss_input_tokens": ["derived.input_minus_cache_hit"],
                "reasoning_tokens": []
            },
            "billing": {
                "input_cache_miss_price_key": "cost_per_1k_input_cache_miss",
                "input_cache_hit_price_key": "cost_per_1k_input_cache_hit",
                "output_price_key": "cost_per_1k_output"
            }
        },
        "openai-compatible": {
            "label": "Generic OpenAI-compatible",
            "request": {
                "chat_api": "openai-compatible",
                "message_format": "openai-chat",
                "image_block": "openai-image-url",
                "tool_name": "openai-compatible"
            },
            "thinking": {"mode_param": "none"},
            "usage": {
                "input_tokens": ["usage.input_tokens", "usage.prompt_tokens"],
                "output_tokens": ["usage.output_tokens", "usage.completion_tokens"],
                "cache_hit_input_tokens": [],
                "cache_miss_input_tokens": ["derived.input_when_no_cache"],
                "reasoning_tokens": []
            }
        }
    },

    "system_models": {
        "_description": "系统提供的大语言模型配置（统一参数源）",
        "system_deepseek": {
            "name": "DeepSeek V3（系统提供）",
            "provider": "deepseek",
            "api_key": "sk-xxx",
            "base_url": "https://api.deepseek.com",
            "model_name": "deepseek-chat",
            "style": "deepseek",
            "context_window": 131072,
            "supports_tools": true,
            "supports_vision": false,
            "supports_multimodal": false,
            "supports_thinking": true,
            "thinking_mode": "optional",
            "cost_per_1k_input_cache_miss": 0.002,
            "cost_per_1k_input_cache_hit": 0.0002,
            "cost_per_1k_output": 0.003,
            "cost_currency": "CNY",
            "readonly": true,
            "enabled": true
        },
        "system_moonshot": {
            "name": "kimi-k2.5（系统提供）",
            "provider": "moonshot",
            "api_key": "sk-xxx",
            "base_url": "https://api.moonshot.cn/v1",
            "model_name": "kimi-k2.5",
            "style": "kimi",
            "context_window": 262144,
            "supports_tools": true,
            "supports_vision": true,
            "supports_multimodal": true,
            "supports_thinking": true,
            "thinking_mode": "optional",
            "cost_per_1k_input_cache_miss": 0.004,
            "cost_per_1k_input_cache_hit": 0.001,
            "cost_per_1k_output": 0.021,
            "cost_currency": "CNY",
            "readonly": true,
            "enabled": true
        },
        "system_minimax": {
            "name": "MiniMax-M2.1（系统提供）",
            "provider": "minimax",
            "api_key": "sk-api-xxx",
            "base_url": "https://api.minimaxi.com/v1",
            "model_name": "MiniMax-M2.1",
            "style": "openai-compatible",
            "context_window": 204800,
            "supports_tools": true,
            "supports_vision": false,
            "supports_multimodal": false,
            "supports_thinking": false,
            "thinking_mode": "none",
            "cost_per_1k_input_cache_miss": 0.0021,
            "cost_per_1k_input_cache_hit": 0.0,
            "cost_per_1k_output": 0.0084,
            "cost_currency": "CNY",
            "readonly": true,
            "enabled": true
        }
    },

    "search_services": {
        "_description": "搜索服务 API 密钥，当前仅支持 tavily",
        "tavily": {
            "api_key": "tvly-dev-xxx"
        }
    },

    "ocr_services": {
        "_description": "OCR 图片识别服务配置（用于不支持多模态的LLM降级方案）",
        "baidu": {
            "enabled": false,
            "api_key": "your-baidu-ocr-api-key",
            "secret_key": "your-baidu-ocr-secret-key",
            "api_url": "https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic",
            "token_url": "https://aip.baidubce.com/oauth/2.0/token",
            "description": "百度云通用文字识别（标准版），按调用次数计费"
        },
        "aliyun": {
            "enabled": false,
            "access_key_id": "",
            "access_key_secret": "",
            "description": "阿里云OCR服务"
        },
        "tesseract": {
            "enabled": true,
            "local": true,
            "description": "Tesseract本地OCR，免费但准确率较低，适合测试环境"
        },
        "easyocr": {
            "enabled": true,
            "local": true,
            "description": "EasyOCR 本地OCR，精度较高但首次加载较慢（约1GB模型）"
        },
        "_fallback_strategy": "按优先级尝试：baidu（云端） → easyocr（本地） → tesseract（本地） → 返回空"
    },

    "document_services": {
        "_description": "文档解析服务配置（支持 PDF/Word/Excel，转换为 Markdown 文本）",
        "baidu": {
            "enabled": false,
            "api_key": "your-baidu-api-key",
            "secret_key": "your-baidu-secret-key",
            "submit_url": "https://aip.baidubce.com/rest/2.0/brain/online/v2/parser/task",
            "query_url": "https://aip.baidubce.com/rest/2.0/brain/online/v2/parser/task/query",
            "token_url": "https://aip.baidubce.com/oauth/2.0/token",
            "poll_interval_seconds": 2,
            "poll_max_attempts": 30,
            "description": "百度云智能文档解析，异步提交任务并转为 Markdown，支持 PDF/Word/Excel"
        },
        "_fallback_strategy": "按优先级尝试：baidu（云端） → pdfplumber/python-docx/openpyxl（本地） → 返回错误"
    },

    "mcp_services": {
        "_description": "MCP 服务配置",
        "amap": {
            "enabled": true,
            "mcp_url": "https://mcp.amap.com/sse",
            "transport": "sse",
            "api_key": "xxx",
            "description": "高德地图 MCP 服务，支持地点搜索、路线规划、周边搜索"
        },
        "12306": {
            "enabled": true,
            "mcp_url": "http://localhost:8001/mcp",
            "transport": "streamable_http",
            "description": "12306 火车票查询服务"
        },
        "VariFlight": {
            "enabled": true,
            "mcp_url": "https://ai.variflight.com/servers/aviation/mcp",
            "transport": "streamable_http",
            "description": "VariFlight 飞常准的航班查询 MCP 服务",
            "api_key": "sk-xxx"
        }
    },

    "billing": {
        "_description": "计费相关配置",
        "monthly_credit": 5.0,
        "credit_currency": "CNY",
        "billing_description": "每月抵用金额度"
    },

    "speech_services": {
        "_description": "语音识别服务配置（用于语音转文字，支持百度云 VOP + 本地 faster-whisper 兜底）",
        "baidu": {
            "enabled": false,
            "auth_type": "bearer",
            "_auth_note": "推荐使用 bearer 认证（BCE IAM）：将 auth_type 设为 bearer，填写 bearer_token。",
            "_auth_note2": "也可使用 oauth2 认证：将 auth_type 设为 oauth2，填写 api_key 和 secret_key，但需确保该 App 已在百度云控制台开通语音识别权限。",
            "api_key": "your-baidu-speech-api-key",
            "secret_key": "your-baidu-speech-secret-key",
            "bearer_token": "bce-v3/ALTAK-xxxx/your-signature",
            "api_url": "https://vop.baidu.com/pro_api",
            "token_url": "https://aip.baidubce.com/oauth/2.0/token",
            "dev_pid": 80001,
            "description": "百度云语音识别极速版（pro_api），支持普通话+英语，按调用次数计费"
        },
        "faster_whisper": {
            "enabled": true,
            "local": true,
            "model_size": "tiny",
            "description": "faster-whisper tiny 模型本地推理，免费但首次需下载约 72MB 模型"
        },
        "_fallback_strategy": "按优先级尝试：baidu（云端） → faster_whisper（本地） → 返回错误"
    },

    "other_services": {
        "_description": "其他服务 API 密钥"
    }
}
